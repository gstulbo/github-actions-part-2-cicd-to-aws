# 1. Берем официальный легкий образ Python
FROM python:3.12-slim

# 2. Указываем рабочую директорию внутри контейнера
WORKDIR /app

# 3. Копируем файл зависимостей и устанавливаем их
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 4. Копируем все файлы проекта (код, шаблоны и т.д.) в контейнер
COPY . .

# 5. Команда для запуска приложения
# Мы используем ту же команду, что ты запускала вручную
CMD ["python", "application.py"]
